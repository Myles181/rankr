# ─────────────────────────────────────────
#  Mu$ic-fans Backend — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Server
PORT=4000
SESSION_SECRET=replace_with_long_random_string_here

# Spotify OAuth
# Get these from: developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:4000/auth/spotify/callback

# For artists — separate app or same app with artist scope
SPOTIFY_ARTIST_REDIRECT_URI=http://localhost:4000/auth/spotify/artist/callback

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/mu$ic-fans

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Solana
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
